#!/bin/sh
# ══════════════════════════════════════════════════════════════
# pre-commit hook — blocks all commits directly on 'main'
#
# Installed via:  git config core.hooksPath .githooks
# ══════════════════════════════════════════════════════════════

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$BRANCH" = "main" ]; then
  echo ""
  echo "══════════════════════════════════════════════════════"
  echo "  🚫  COMMIT BLOCKED — You are on 'main'"
  echo "══════════════════════════════════════════════════════"
  echo ""
  echo "  Direct commits to 'main' are not allowed."
  echo "  All changes must go through a Pull Request."
  echo ""
  echo "  To fix this, create a new branch first:"
  echo ""
  echo "    git checkout -b feature/your-change"
  echo "    git add ."
  echo "    git commit -m \"your message\""
  echo "    git push origin feature/your-change"
  echo ""
  echo "  Allowed branch prefixes:"
  echo "    feature/*   fix/*   hotfix/*"
  echo "    chore/*     refactor/*   release/*   dev/*"
  echo ""
  echo "══════════════════════════════════════════════════════"
  exit 1
fi

exit 0
